<%- include('../partials/header') %>
<div class="container form-page">
  <h1 class="page-title">Nouvelle annonce</h1>
  <% if (locals.errors && errors.length) { %>
    <ul class="errors-list"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
  <% } %>
  <form method="POST" action="/listings/create" enctype="multipart/form-data" class="form-card">
    <div class="form-group">
      <label for="title">Titre</label>
      <input type="text" id="title" name="title" value="<%= old.title || '' %>" required maxlength="100">
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4" required maxlength="1000"><%= old.description || '' %></textarea>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="category">Catégorie</label>
        <select id="category" name="category" required>
          <option value="">-- Choisir --</option>
          <% categories.forEach(c => { %>
            <option value="<%= c %>" <%= old.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="listing_type">Type</label>
        <select id="listing_type" name="listing_type" required>
          <option value="">-- Choisir --</option>
          <% types.forEach(t => { %>
            <option value="<%= t %>" <%= old.listing_type === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="location">Lieu</label>
        <input type="text" id="location" name="location" value="<%= old.location || '' %>" required maxlength="100">
      </div>
      <div class="form-group">
        <label for="price">Prix (€) <small>si vente</small></label>
        <input type="number" id="price" name="price" value="<%= old.price || '' %>" min="0" step="0.01">
      </div>
    </div>
    <div class="form-group">
      <label for="image">Image <small>(facultatif, max 5 Mo)</small></label>
      <input type="file" id="image" name="image" accept="image/*">
    </div>
    <button type="submit" class="btn-primary btn-block">Publier l'annonce</button>
  </form>
</div>
<%- include('../partials/footer') %>
