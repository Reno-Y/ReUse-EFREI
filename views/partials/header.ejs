<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — ReUse EFREI</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header class="site-header">
  <nav class="nav-inner">
    <a href="/" class="nav-brand">ReUse EFREI</a>
    <ul class="nav-links">
      <li><a href="/listings">Annonces</a></li>
      <% if (user) { %>
        <li><a href="/dashboard">Mon espace</a></li>
        <% if (user.role === 'admin') { %>
          <li><a href="/users">Utilisateurs</a></li>
        <% } %>
        <li>
          <form method="POST" action="/logout" style="display:inline">
            <button type="submit" class="btn-link">Déconnexion</button>
          </form>
        </li>
      <% } else { %>
        <li><a href="/login">Connexion</a></li>
        <li><a href="/register" class="btn-primary-sm">Inscription</a></li>
      <% } %>
    </ul>
  </nav>
</header>
<main class="main-content">
<% if (flash.success) { %>
  <div class="flash flash-success"><%= flash.success %></div>
<% } %>
<% if (flash.error) { %>
  <div class="flash flash-error"><%= flash.error %></div>
<% } %>
