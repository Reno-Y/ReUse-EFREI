<%- include('../partials/header') %>
<div class="container form-page">
  <h1 class="page-title">Modifier l'annonce</h1>
  <% if (locals.errors && errors.length) { %>
    <ul class="errors-list"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
  <% } %>
  <form method="POST" action="/listings/<%= listing.id %>/edit" enctype="multipart/form-data" class="form-card">
    <div class="form-group">
      <label for="title">Titre</label>
      <input type="text" id="title" name="title" value="<%= old.title || '' %>" required maxlength="100">
    </div>
    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4" required maxlength="1000"><%= old.description || '' %></textarea>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="category">Catégorie</label>
        <select id="category" name="category" required>
          <% categories.forEach(c => { %>
            <option value="<%= c %>" <%= old.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="listing_type">Type</label>
        <select id="listing_type" name="listing_type" required>
          <% types.forEach(t => { %>
            <option value="<%= t %>" <%= old.listing_type === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="status">Statut</label>
        <select id="status" name="status" required>
          <% statuses.forEach(s => { %>
            <option value="<%= s %>" <%= old.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="location">Lieu</label>
        <input type="text" id="location" name="location" value="<%= old.location || '' %>" required maxlength="100">
      </div>
      <div class="form-group">
        <label for="price">Prix (€) <small>si vente</small></label>
        <input type="number" id="price" name="price" value="<%= old.price != null ? old.price : '' %>" min="0" step="0.01">
      </div>
    </div>
    <% if (listing.image_path) { %>
      <div class="form-group">
        <p class="text-muted">Image actuelle :</p>
        <img src="<%= listing.image_path %>" alt="Image actuelle" loading="lazy" style="max-width:200px;border-radius:4px">
      </div>
    <% } %>
    <div class="form-group">
      <label for="image">Nouvelle image <small>(remplace l'actuelle, max 5 Mo)</small></label>
      <input type="file" id="image" name="image" accept="image/*">
    </div>
    <button type="submit" class="btn-primary btn-block">Enregistrer les modifications</button>
  </form>
</div>
<%- include('../partials/footer') %>
