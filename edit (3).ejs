<%- include('../partials/header') %>
<div class="container">
  <a href="/listings" class="back-link">&larr; Retour aux annonces</a>

  <article class="detail-card">
    <% if (listing.image_path) { %>
      <img src="<%= listing.image_path %>" alt="<%= listing.title %>" loading="lazy" class="detail-img">
    <% } %>
    <div class="detail-body">
      <div class="detail-badges">
        <span class="badge badge-<%= listing.listing_type %>"><%= listing.listing_type %></span>
        <span class="badge badge-cat"><%= listing.category %></span>
        <span class="badge badge-status-<%= listing.status %>"><%= listing.status %></span>
      </div>
      <h1 class="page-title"><%= listing.title %></h1>
      <p class="detail-meta">
        Publié par <strong><%= listing.first_name %> <%= listing.last_name %></strong>
        &bull; <%= listing.location %>
        <% if (listing.listing_type === 'vente' && listing.price != null) { %>
          &bull; <strong class="price"><%= listing.price.toFixed(2) %> €</strong>
        <% } %>
      </p>
      <p class="detail-desc"><%= listing.description %></p>
      <p class="text-muted"><small>Publié le <%= listing.created_at.slice(0, 10) %></small></p>

      <% if (user && (user.id === listing.owner_id || user.role === 'admin')) { %>
        <div class="detail-actions">
          <a href="/listings/<%= listing.id %>/edit" class="btn-secondary">Modifier</a>
          <a href="/listings/<%= listing.id %>/delete" class="btn-danger">Supprimer</a>
        </div>
      <% } %>
    </div>
  </article>
</div>
<%- include('../partials/footer') %>
