<%- include('partials/header') %>
<div class="container">
  <h1 class="page-title">Bonjour, <%= user.first_name %> !</h1>

  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-num"><%= counts.active %></span>
      <span class="stat-label">Active<%= counts.active > 1 ? 's' : '' %></span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= counts.reservee %></span>
      <span class="stat-label">Réservée<%= counts.reservee > 1 ? 's' : '' %></span>
    </div>
    <div class="stat-card">
      <span class="stat-num"><%= counts.terminee %></span>
      <span class="stat-label">Terminée<%= counts.terminee > 1 ? 's' : '' %></span>
    </div>
  </div>

  <div class="section-header">
    <h2>Mes annonces</h2>
    <a href="/listings/create" class="btn-primary">+ Nouvelle annonce</a>
  </div>

  <% if (listings.length === 0) { %>
    <p class="text-muted">Vous n'avez pas encore d'annonces. <a href="/listings/create">Publiez votre première annonce</a>.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Titre</th>
            <th>Type</th>
            <th>Statut</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% listings.forEach(l => { %>
            <tr>
              <td><a href="/listings/<%= l.id %>"><%= l.title %></a></td>
              <td><span class="badge badge-<%= l.listing_type %>"><%= l.listing_type %></span></td>
              <td><span class="badge badge-status-<%= l.status %>"><%= l.status %></span></td>
              <td class="text-muted"><%= l.created_at.slice(0, 10) %></td>
              <td class="actions-cell">
                <a href="/listings/<%= l.id %>/edit" class="btn-sm">Modifier</a>
                <a href="/listings/<%= l.id %>/delete" class="btn-sm btn-danger">Supprimer</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div class="section-header" style="margin-top:2rem">
    <h2>Mon profil</h2>
    <a href="/users/<%= user.id %>/edit" class="btn-secondary">Modifier mon profil</a>
  </div>
  <p class="text-muted"><%= user.email %></p>
</div>
<%- include('partials/footer') %>
