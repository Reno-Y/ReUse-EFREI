<%- include('../partials/header') %>
<div class="container form-page">
  <div class="card danger-card">
    <h1 class="page-title">Supprimer l'annonce</h1>
    <p>Êtes-vous sûr de vouloir supprimer l'annonce <strong>« <%= listing.title %> »</strong> ?</p>
    <p class="text-muted">Cette action est irréversible.</p>
    <div class="confirm-actions">
      <form method="POST" action="/listings/<%= listing.id %>/delete">
        <button type="submit" class="btn-danger">Oui, supprimer</button>
      </form>
      <a href="/dashboard" class="btn-secondary">Annuler</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
